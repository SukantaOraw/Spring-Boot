<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.springframework.org/schema/beans
                           http://www.springframework.org/schema/beans/spring-beans.xsd">


    <bean id="student" class="com.invictus.springpractice.Student">
        <!-- <property name="name" value="Default Student Name"/> -->
        <!-- Property -> Setter injection -->
        <constructor-arg name="name" value="Sukanta"/>
        <constructor-arg name="major" value="CSE"/>
        <!-- Constructor Injection -> Using Names -->
        <constructor-arg name="laptop" ref="laptop"/>
    </bean>

    <bean id="laptop" class="com.invictus.springpractice.Laptop">
        <constructor-arg name="brand" value="Asus"/>
        <!-- Constructor Injection -> Using Names          -->
    </bean>


</beans>